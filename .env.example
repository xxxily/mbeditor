# MBEditor 环境变量配置
# 复制本文件为 .env：cp .env.example .env
# 然后在 Agent 或终端中使用 source .env 加载。

# =====================
# 基础服务地址（Agent 操作 API 时读取）
# =====================

# API 服务地址 — Agent 用来调用文章/图片/发布等端点
MBEDITOR_API_BASE=http://localhost:7072

# Web 编辑器地址 — Agent 用来看前端预览效果
MBEDITOR_WEB_BASE=http://localhost:7073

# =====================
# 部署在其他服务器时的设置
# =====================

# 示例：部署在 123.45.67.89 上
# MBEDITOR_API_BASE=http://123.45.67.89:7072
# MBEDITOR_WEB_BASE=http://123.45.67.89:7073

# =====================
# 测试控制（可选）
# =====================

# 开启真实微信 API 调用测试（默认关闭，防止意外调用）
# MBEDITOR_RUN_REAL_WECHAT_TESTS=0

# 开启视觉 diff 自动写基准文件（仅开发测试用）
# MBEDITOR_VISUAL_WRITE_DIFF=0
