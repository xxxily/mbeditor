# Dependencies
frontend/node_modules/
backend/__pycache__/
**/__pycache__/
*.pyc

# Build output
frontend/dist/

# Data (user-generated)
data/images/
data/articles/
data/config.json
data/*.html
!data/.gitkeep
!data/config.json.example

# Dev-only runtime data dir (when running uvicorn from ./backend with
