backend/data/

# TypeScript build info (regenerated by editor/tsc on every build)
frontend/tsconfig.tsbuildinfo
frontend/.logs/

# Environment
.env
.env.*

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Development tools
# NOTE: docs/superpowers/ is tracked so any future session / collaborator
# can resume the WYSIWYG refactor from any stage (plans, handoff,
# orchestration framework, research reports).
CLAUDE.md
.playwright-mcp/

# Playwright visual test artifacts and auth state
backend/tests/visual/.auth/
backend/tests/visual/_artifacts/

# pip install -e artifacts
*.egg-info/

# Local agent / session state (not portable across machines)
.claude/
.omx/
data/mbdocs/
