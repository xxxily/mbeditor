# Normalize line endings across platforms
# Prevents Windows `core.autocrlf=true` from breaking shell scripts in Docker
* text=auto eol=lf

# Shell scripts must be LF (executed inside Linux containers)
*.sh text eol=lf

# Windows batch files must be CRLF
*.bat text eol=crlf
*.cmd text eol=crlf

# Binary files – never normalize
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.woff binary
*.woff2 binary
